# Copy to `.env` and adjust as needed. NEVER commit the real `.env`.
# This rules-based service needs no secrets.

# Port the HTTP server binds to. Most PaaS platforms inject this automatically.
PORT=8000

# Number of server worker processes. Set to the number of CPU cores in
# production for higher throughput.
WEB_CONCURRENCY=1

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120          # allowed requests per window, per client IP
RATE_LIMIT_WINDOW_SECONDS=60     # length of the window in seconds
TRUST_PROXY_HEADERS=true         # read client IP from X-Forwarded-For (PaaS/CDN)

# Optional: a Redis URL enables ONE shared limit across all instances/workers
# (required for accurate limiting when scaling horizontally). If unset, an
# in-memory per-process limiter is used.
# REDIS_URL=redis://localhost:6379/0

# --- Request limits ---------------------------------------------------------
MAX_BODY_BYTES=65536             # reject bodies larger than this (413)
MAX_MESSAGE_LENGTH=10000         # reject longer `message` values (422)
MAX_TICKET_ID_LENGTH=200

# --- Misc -------------------------------------------------------------------
ENABLE_DOCS=true                 # set false to hide /docs and /openapi.json
LOG_LEVEL=INFO
