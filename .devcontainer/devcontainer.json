{
  "name": "QueueStorm Ticket Sorter",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "api",
  "workspaceFolder": "/app",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "API", "onAutoForward": "notify" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.testing.pytestEnabled": true
      }
    }
  },
  "postCreateCommand": "pip install --no-cache-dir -r requirements-dev.txt",
  "remoteUser": "appuser"
}
